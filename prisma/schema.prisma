// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int          @id @default(autoincrement())
  name          String
  email         String       @unique
  phone         String?
  passwordHash  String
  role          UserRole     @default(STUDENT)
  isEmailConfirmed       Boolean  @default(false)
  confirmEmailToken      String?
  resetPasswordToken     String?
  resetPasswordExpire    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // relations
  courses       Course[]     @relation("InstructorCourses")
  enrollments   Enrollment[]
  reviews       Review[]
  payments      Payment[]
  lessonProgress LessonProgress[]  
}

model Course {
  id            Int          @id @default(autoincrement())
  title         String
  description   String
  thumbnail     String?
  duration      Int?
  level         CourseLevel
  language      String
  price         Decimal      @db.Decimal(10, 2)
  rating        Decimal?     @db.Decimal(3, 2)
  status        CourseStatus
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // relations
  instructorId  Int?
  instructor    User?         @relation("InstructorCourses", fields: [instructorId], references: [id])

  modules       Module[]
  enrollments   Enrollment[]
  reviews       Review[]
  payments      Payment[]
}

model Module {
  id          Int       @id @default(autoincrement())  
  title       String
  sortOrder   Int
  createdAt   DateTime  @default(now())

  // relations
  courseId  Int
  course    Course    @relation(fields: [courseId], references: [id])
  lessons   Lesson[]
}

model Lesson {
  id          Int       @id @default(autoincrement())     
  video_id    String?
  library_id  Int?
  title       String
  videoUrl    String
  duration    Int?
  sortOrder   Int
  isPreview   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // relations
  moduleId  Int
  module    Module    @relation(fields: [moduleId], references: [id])
  progress  LessonProgress[] 
}

model Enrollment {
  id         Int              @id @default(autoincrement())
  status     EnrollmentStatus
  enrolledAt DateTime         @default(now())

  // relations
  userId     Int
  courseId   Int
  user       User             @relation(fields: [userId], references: [id])
  course     Course           @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model LessonProgress {
  id          Int      @id @default(autoincrement())
  isCompleted Boolean  @default(false)
  completedAt DateTime?

  userId      Int
  lessonId    Int

  user        User    @relation(fields: [userId], references: [id])
  lesson      Lesson  @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}


model Review {
  id        Int       @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime  @default(now())

  // relations
  userId    Int
  courseId  Int
  user      User      @relation(fields: [userId], references: [id])
  course    Course    @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Blog {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String   @db.Text
  published   Boolean  @default(false)

  coverImageId Int?
  coverImage   Media?   @relation("BlogCover", fields: [coverImageId], references: [id])

  // 2. You MUST add "BlogGallery" here to match Media
  gallery      Media[]  @relation("BlogGallery")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        Int       @id @default(autoincrement())
  url       String
  type      MediaType
  provider  String?

  alt       String?
  size      Int?
  mimeType  String?

  coveredBlogs  Blog[] @relation("BlogCover")   
  galleryBlogs  Blog[] @relation("BlogGallery")

  createdAt DateTime  @default(now())
}

model Payment {
  id            Int           @id @default(autoincrement())
  amount        Decimal?       @db.Decimal(10, 2)
  currency      String?
  paymentMethod String
  transactionId String        @unique
  status        PaymentStatus
  createdAt     DateTime      @default(now())

  // relations
  userId        Int
  courseId      Int
  user          User          @relation(fields: [userId], references: [id])
  course        Course        @relation(fields: [courseId], references: [id])
}

model BkashTransaction {
  id           Int         @id @default(autoincrement())
  txid         String      @unique
  amount       Decimal     @db.Decimal(10, 2)
  rawMessage   String
  senderNumber String?
  status       BkashStatus @default(UNMATCHED)
  createdAt    DateTime    @default(now())
}

model Event {
  id              Int      @id @default(autoincrement())
  title           String
  date            String
  location        String
  attendees       String?
  registrationUrl String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

/* ================= ENUMS ================= */

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
  SUPERADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BkashStatus {
  UNMATCHED
  MATCHED
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
}